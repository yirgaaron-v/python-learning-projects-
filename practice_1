import random
def random_temp(min=200, max=1200):
    temperature = random.randint(min, max)
    return temperature

def neuclear(min=0 , max=800):
    neutrons_emitted = random.randint(min, max)
    return neutrons_emitted

def neuclear_persec(min=0 , max=50000):
    neutrons_emitted_per_min = random.randint(min, max)
    return neutrons_emitted_per_min

print(random_temp())
print(neuclear())
print(neuclear_persec())

def are_conds_met(temperature, neutrons_emitted, neutrons_emitted_per_min):
    if temperature >= 200 and temperature <= 800 and neutrons_emitted > 500 and neutrons_emitted_per_min > 20000:
        return True
    else:
        return False
print(are_conds_met(random_temp(), neuclear(), neuclear_persec()))