import random

def drift_temperature(current_temp):
    change = random.gauss(0, 50)
    new_temp = current_temp + change
    return max(0, min(2000, new_temp))

temp = 500
for tick in range(20):
    temp = drift_temperature(temp)
    print(f"Tick {tick + 1}: {temp:.1f}°C")

print("Final Temperature:", temp)
