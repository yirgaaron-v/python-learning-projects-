student_names =  ['Joci', 'Sara','Kora','Jan','John','Bern', 'Fred']

def student_ranking(student_scores, student_names):
    rankings = []

    for  i in range(len(student_scores)):
        rankings.append(f"{i + 1}. {student_names[i]}: {student_scores[i]}")

    return rankings
